meta:
  schemaVersion: 1
  storyId: "test_story"
  entryNodeId: "N_TestStory_001"

variables: []

nodes:
  - nodeId: "N_TestStory_001"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "1995年7月。东京。梅雨季节尚未结束，空气闷热潮湿，蝉鸣声从远处传来，断断续续，像是某种不祥的预兆。"
        - textKey: "17岁的森山千夏站在镰仓大船站的站台上，手中紧握着一只旧皮箱。箱子里装着几套换洗衣物和一本边角已经微微卷起的素描本——那是高中美术老师桐原美咲送给她的毕业礼物。"
        - textKey: "千夏浅蓝色的齐肩短发在闷热潮湿的空气中轻轻贴在脸颊上。淡粉色的瞳孔倒映着站台上的霓虹灯牌，眼神中有一种与年龄不符的忧郁。"
        - textKey: "她的左手无意识地攥紧了皮箱的把手，那只手的腕部内侧有一道浅浅的、已经泛白的疤痕。"
        - textKey: "那是继父留下的。"
  - nodeId: "N_TestStory_002"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "（低声）…反正我这种人。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_003"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "传呼机突然震动起来，发出滴滴滴的提示音。千夏从裙子的口袋里掏出它——黑色的摩托罗拉BP机，屏幕上绿色的背光在昏暗的站台上格外醒目。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_004"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉（传呼机留言）"
      textKey: "今天会是你人生中最美好的一天。我已经等不及要见你了。你画的那只猫，我已经想象了无数次它的样子。——拓哉"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_005"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏看着那行字，嘴角不自觉地微微上扬。这是半年来第一个让她发自内心微笑的人。"
        - textKey: "在BBS美术讨论版上认识拓哉的时候，千夏并没有抱太大期待。网络上的人都只是过客，这是她17年人生中学到的教训之一。"
        - textKey: "但拓哉不一样。他认真评论她的每一幅涂鸦，指出构图的问题，讨论太宰治小说中的隐喻。他从不说画得不错这种敷衍的话，而是真正看懂了她的画。"
  - nodeId: "N_TestStory_006"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "\"你的眼睛像在诉说着什么。\""
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_007"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "那是拓哉对她画的第一只猫的评价。继父从未正眼看过她的画。母亲由美只会说还行。美术老师虽然鼓励她，但终究只是老师的客气。"
        - textKey: "只有拓哉，隔着网线，看懂了那只猫眼睛里的孤独。"
        - textKey: "电车进站的提示音响起。千夏最后看了一眼这个她生活了17年的城市——镰仓的海、镰仓的山、还有那个她称之为家却从不属于她的狭小公寓。"
  - nodeId: "N_TestStory_008"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "我走了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_009"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "她踏上了开往足利市的电车。车厢内冷气开得很足，千夏坐在靠窗的位置上，将素描本紧紧抱在怀里。"
        - textKey: "窗外的风景从熟悉的镰仓街道逐渐变成陌生的乡野景色。稻田、小河、偶尔掠过的鸟居——千夏从未出过这么远的门。"
        - textKey: "对面坐着一位老妇人，正在织毛衣。她看了看千夏，又看了看千夏怀里的素描本，露出慈祥的微笑。"
  - nodeId: "N_TestStory_010"
    nodeType: Dialogue
    dialogue:
      speakerId: "老妇人"
      textKey: "去足利啊？很远呢。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_011"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "嗯…去见朋友。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_012"
    nodeType: Dialogue
    dialogue:
      speakerId: "老妇人"
      textKey: "男朋友？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_013"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "不、不是！只是…网友。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_014"
    nodeType: Dialogue
    dialogue:
      speakerId: "老妇人"
      textKey: "网友啊。现在的年轻人真厉害。我们那时候连电话都没普及呢。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_015"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "老妇人继续织毛衣，不再说话。千夏松了口气，低头翻开素描本。"
        - textKey: "她翻到那一页——那只猫。画中的猫蜷缩在角落，眼睛看向画面外，眼神忧郁而警惕。千夏画它的时候，心里想的是继父醉醺醺回家的夜晚。"
        - textKey: "那时候她总会躲进壁橱里，抱着画本，在黑暗中一笔一笔地画。画出她不敢说出口的话。"
        - textKey: "电车轻微颠簸。千夏闭上眼睛，左手无意识地摸向左腕的疤痕。"
        - textKey: "\"赔钱货。\"\"你除了画画还会什么？\"\"你以为你能靠这个吃饭？\""
        - textKey: "\"咔嗒。\"——继父施暴前必定掰响左手小指关节的声音。这个声音已经深深刻进了千夏的骨髓里。"
        - textKey: "千夏猛地睁开眼睛。她把手缩回袖子里，深呼吸。今天是不同的日子。她要去见一个完全不同的人。"
        - textKey: "电车广播响起：下一站，足利市。足利市的乘客请准备下车。"
  - nodeId: "N_TestStory_016"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "到了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_017"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏提着皮箱走出车厢。足利市的阳光比镰仓更刺眼，也更干燥。她眯起眼睛，适应着新的光线。"
        - textKey: "站台上人不多。千夏四处张望，心跳加速——她只在BBS上看过拓哉发的照片，一张模糊的侧脸。"
  - nodeId: "N_TestStory_018"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "千夏？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_019"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏转身。"
        - textKey: "站在她面前的男人比BBS照片上更年轻。25岁左右，黑色短发打理得一丝不苟，最引人注目的是那双金色的瞳孔——在阳光下像猫科动物一样微微收缩。右眼眼角有一颗泪痣，为他温文尔雅的外表增添了一丝神秘的气质。"
        - textKey: "他穿着干净的白衬衫，袖子挽到手肘，露出纤细但结实的手臂。手里拿着一本《人间失格》，书角微微卷起——那是经常翻阅的痕迹。"
        - textKey: "没有酒气。没有烟味。没有令人恐惧的小指关节声。"
  - nodeId: "N_TestStory_020"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "叫我拓哉就好。你比BBS上描述的样子更可爱。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_021"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏的脸微微泛红。拓哉的打量不是那种令人不适的凝视，而是欣赏的目光——像在美术馆里看一幅喜欢的画。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_022"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "你…和我想象的不太一样。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_023"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "哪里不一样？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_024"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "更…普通？我以为会是个大叔。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_025"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "哈哈。让你失望了？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_026"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "没有。比想象的好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_027"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "走吧。我带你去一家很棒的咖啡馆。那里有超大落地窗，下午的光线特别适合画画。而且——"
        - textKey: "而且店主允许客人随便涂鸦。"
  - nodeId: "N_TestStory_028"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "拓哉接过皮箱的动作自然得体，没有任何令人不适的肢体接触。他的手指修长干净，指甲修剪得整整齐齐——不像继父那样粗糙肮脏。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_029"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_030"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "两人走在足利市的街道上。拓哉刻意放慢脚步配合千夏的步速，两人保持着大约半米的距离——不远不近，恰到好处。"
        - textKey: "街道上行人稀少，偶尔有骑着自行车的学生路过。和东京完全不同的节奏。千夏觉得这里的空气都有一种陌生的自由味道。"
  - nodeId: "N_TestStory_031"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "足利是个小地方。没什么好玩的。但我很喜欢这里的安静。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_032"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "比东京安静多了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_033"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "东京太吵了。到处都是人，到处都是声音。有时候我觉得自己会被淹没。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_034"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "我也是。我在家里…没办法画画。太吵了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_035"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "家里有人打扰你吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_036"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏沉默了一秒。继父的脸在脑海中闪过。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_037"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "…就是普通的家庭。弟弟很吵。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_038"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "她没有弟弟。但继父的存在不是可以随便对陌生人说出口的话题。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_039"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "（微笑）那我带你去一个绝对安静的地方。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_040"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "巷子越走越窄，两旁的老房子上爬满了常春藤。拓哉在一扇木门前停下脚步。"
        - textKey: "木门旁边种着一丛紫色的绣球花，花开得正好，在微风中轻轻摇曳。门牌上写着镜花水月四个字，笔迹潦草但有力。"
  - nodeId: "N_TestStory_041"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "就是这里。我发现在足利最好的秘密基地。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_042"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "门上的铜铃发出清脆的响声。咖啡馆内部比想象中宽敞，暖色调的橘黄色灯光铺满整个空间。"
        - textKey: "靠窗的位置有一排高脚凳，正对着落地窗。下午的阳光透过纱帘洒进来，在木质地板上投下斑驳的光影。"
        - textKey: "墙上挂满了各种画作——有些看起来是专业画家的作品，有些明显是客人的涂鸦。角落里甚至有一面涂鸦墙，上面层层叠叠地画满了各种图案和签名。"
  - nodeId: "N_TestStory_043"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "好棒的地方…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_044"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "坐这边。光线最好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_045"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏在高脚凳上坐下，将素描本放在吧台上。拓哉坐在她对面，中间隔着一本菜单。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_046"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "这家的伯爵红茶很出名。不过如果你喜欢咖啡，他们的手冲也很棒。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_047"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "红茶就好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_048"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "拓哉起身去点单。千夏趁这个空隙环顾四周。"
        - textKey: "她注意到墙上有一幅画——一只黑色的猫，蜷缩在月光下。画的风格和千夏的素描有几分相似。"
        - textKey: "画框下方有一行小字：1994年春，由纪。"
        - textKey: "千夏正想仔细看，拓哉端着托盘回来了。"
  - nodeId: "N_TestStory_049"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "给你。还有这个——他们的抹茶蛋糕是必点的。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_050"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "谢谢…多少钱？我AA吧。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_051"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "不用。我邀请你来的，当然是我请。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_052"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "拓哉的手指接触到千夏的手背。温暖，干燥，令人意外地安心。千夏迅速收回手，心跳漏了一拍。"
        - textKey: "不是恐惧的心跳。是另一种她几乎已经忘记的感觉——被人温柔对待时的心动。"
  - nodeId: "N_TestStory_053"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "对了，给我看看你的画吧。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_054"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏犹豫了一下，还是翻开素描本。她翻到那幅四格漫画——一只猫从警惕到信任的故事。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_055"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "这只猫画得很好。"
        - textKey: "尤其是眼睛。从第一格的警惕到第四格的信任——你画出了它的心路历程。"
  - nodeId: "N_TestStory_056"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "真的吗？我画了三个晚上…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_057"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "三个晚上？那你的速度还不错。我刚开始学画的时候，一幅简单的静物就要画一周。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_058"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "你也会画画？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_059"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "大学的时候学过一点。后来工作了就没时间了。"
        - textKey: "不过看别人的画也是一种享受。尤其是懂画的人。"
  - nodeId: "N_TestStory_060"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏感到眼眶有些湿润。继父从未赞美过她的画。母亲也只是说画得还行。美术老师虽然鼓励她，但终究只是老师的客气。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_061"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "谢谢你。从来没有人…这样说过。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_062"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "那他们的眼睛都瞎了。"
        - textKey: "千夏，你有才华。真的。不应该被埋没。"
  - nodeId: "N_TestStory_063"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏抬头看着拓哉。那双金色瞳孔中闪烁的不是客套，而是真实的欣赏。千夏在这一刻觉得，也许自己并不是一无是处。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_064"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "我有一个提议——"
        - textKey: "你愿意去我的工作室看看吗？"
        - textKey: "那里有很多初版书和画集。而且…有一整面墙的画具。你可以随便用。"
  - nodeId: "N_TestStory_065"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏犹豫了。她想起母亲的叮嘱：不要太晚回来。想起继父醉醺醺的脸。但拓哉的目光中没有令她恐惧的东西。那是一种她从未体验过的被接纳的感觉。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_066"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_067"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "两人离开咖啡馆时，夕阳已经将整条街道染成了橘红色。拓哉走在前面带路，千夏跟在后面。"
        - textKey: "千夏不知道，前方等待她的，不是艺术的殿堂，而是另一座更深、更精致的囚笼。"
        - textKey: "夕阳将两人的影子拉得很长。千夏踩着自己的影子，一步一步，走向未知的命运。"
        - textKey: "拓哉的工作室位于一栋建于昭和年代的老旧公寓三楼。楼梯间的灯泡忽明忽暗，投下诡异的阴影。"
  - nodeId: "N_TestStory_068"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "就是这里。别嫌弃，老房子了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_069"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "门上的铜铃发出比咖啡馆更沉闷的响声。千夏跟着拓哉走进房间。"
        - textKey: "房间不大，大约二十坪，但整洁得令人惊讶。每一件物品都有它固定的位置。书架上按颜色和高度排列着书籍，茶几上的杂志边缘对齐，沙发上的靠垫摆成完美的对称。"
  - nodeId: "N_TestStory_070"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "好干净…你自己打扫的吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_071"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "嗯。我有轻微的强迫症。东西不摆好就会浑身不舒服。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_072"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "衣架上只挂着两件外套——一件是拓哉刚才脱下的米色风衣，另一件是黑色的女式短外套。千夏注意到这件外套的尺寸明显小于拓哉的。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_073"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "那件外套是…？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_074"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "哦，前女友的。她落在这里了，一直没来拿。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_075"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏点点头，没有追问。但她注意到，那件外套挂得整整齐齐，没有一丝灰尘——不像是一件被遗忘的物品。"
        - textKey: "千夏走向书架。太宰治、三岛由纪夫、村上春树、谷崎润一郎…都是她在BBS上提过的作家。每一本书都包着透明的书皮，书脊上贴着分类标签。"
        - textKey: "太宰治—代表作—1940s。三岛由纪夫—美学论。标签上的字迹工整得像是印刷体。"
  - nodeId: "N_TestStory_076"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "你分类得好详细…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_077"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "做研究习惯了。不把东西整理好就没办法思考。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_078"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏继续浏览。在书架的最底层，她发现了一个不寻常的细节——那一层的书籍排列方式和上面几层完全不同。"
        - textKey: "上层的书是按颜色分类的，红橙黄绿青蓝紫，美观而整齐。但底层的书…是按大小编排的，而且书脊朝向内侧，看不到书名。"
        - textKey: "千夏假装在找书，蹲下身偷偷看了一眼。最外面的一本书侧面写着：心理学—操控术。"
        - textKey: "千夏的心跳漏了一拍。但她立刻说服自己——拓哉是制药公司的研发主管，看心理学书籍也不奇怪。"
  - nodeId: "N_TestStory_079"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "找到喜欢的了吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_080"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "啊，还没…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_081"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "来，先喝点茶。这是朋友从京都带来的宇治抹茶。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_082"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏接过茶杯。温热的陶瓷触感让她想起母亲——由美也喜欢在深夜泡一杯茶，放在千夏的房门外。"
        - textKey: "千夏6岁时父母离异。由美带着她改嫁给了森山健二。起初继父表现得还算正常，但从千夏12岁那年起，一切都变了。"
        - textKey: "健二开始酗酒。最初只是偶尔喝醉骂人，后来变成了一喝醉就动手。千夏学会在听到车库门打开的声音时立刻躲进房间。"
        - textKey: "\"咔嗒。\"——左手小指关节的脆响。那是暴风雨来临前的信号。千夏会在听到这个声音后的一分钟内锁上房门、关灯、钻进壁橱、屏住呼吸。"
  - nodeId: "N_TestStory_083"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "（低声）…没什么。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_084"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "嗯？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_085"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "我说…茶很好喝。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_086"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "拓哉微笑着看着千夏。那双金色瞳孔在暖色灯光下显得格外深邃。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_087"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "千夏。你喜欢这里吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_088"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "嗯。很安静。和东京完全不一样。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_089"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "那你愿意…在这里待久一点吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_090"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏没有理解这句话的含义。她以为拓哉只是在客气地挽留。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_091"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "呃…我是明天的回程电车。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_092"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "…是吗。"
        - textKey: "那今晚就好好享受吧。"
  - nodeId: "N_TestStory_093"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏点点头，继续喝茶。窗外的天色已经完全暗了下来。"
        - textKey: "她不知道的是，那杯茶里已经加入了一种特殊的成分。"
        - textKey: "千夏的意识逐渐模糊。她努力想要站起来，却发现四肢像灌了铅一样沉重。"
  - nodeId: "N_TestStory_094"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "拓哉…我…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_095"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "睡吧。醒来之后，一切都会变得更好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_096"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏的世界陷入黑暗。在失去意识的最后一刻，她看到了拓哉金色瞳孔中闪烁的——不是温柔，而是一种令人毛骨悚然的满足。"
        - textKey: "千夏的画笔从手中滑落。素描本翻开的那一页上，那只猫的眼睛正无助地注视着这一切。"
        - textKey: "黑暗。无边无际的黑暗。"
        - textKey: "千夏的意识像溺水者一样挣扎着浮出水面。她感到头痛欲裂，四肢无力。"
  - nodeId: "N_TestStory_097"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "…这是哪里？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_098"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "她发现自己躺在一张陌生的床上。房间不大，但收拾得很整洁。窗帘拉得严严实实，看不到外面是白天还是黑夜。"
        - textKey: "床头柜上放着一杯水和一张便签。千夏挣扎着坐起来，拿起便签。"
  - nodeId: "N_TestStory_099"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉（传呼机留言）"
      textKey: "\"抱歉用这种方式。你喝了那杯茶之后睡着了，我不忍心叫醒你，就把你搬到客房了。早餐在桌上。——拓哉\""
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_100"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "什么…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_101"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏努力回忆昨晚发生的事。她记得喝茶、和拓哉聊天…然后…一片空白。"
        - textKey: "她摇摇晃晃地站起来，走到门边。门把手转动——"
        - textKey: "锁着的。"
  - nodeId: "N_TestStory_102"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "锁…锁着？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_103"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏用力转动门把手，又推又拉。门纹丝不动。"
        - textKey: "她跑到窗边拉开窗帘——窗外是三楼的高度，铁栅栏封死了整个窗户。"
  - nodeId: "N_TestStory_104"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "为什么…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_105"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "门锁的声音从门外传来。千夏惊恐地后退。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_106"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "早安。睡得好吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_107"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "拓哉…门为什么锁着？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_108"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "哦，那个啊。"
        - textKey: "自动锁。这栋楼很旧了，每个房间的门都会自动上锁。"
  - nodeId: "N_TestStory_109"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "那把钥匙呢？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_110"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "房东拿着。他这几天不在。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_111"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "那我怎么回家？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_112"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "千夏，冷静一点。"
        - textKey: "你现在状态不好。昨天那杯茶里我加了一点助眠的东西。你现在可能还有些头晕。"
        - textKey: "等你恢复了，我再想办法联系房东。好吗？"
  - nodeId: "N_TestStory_113"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏想要反驳，但一阵眩晕袭来。她不得不扶住墙壁。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_114"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "…我需要给家里人打个电话。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_115"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "电话线断了。这栋楼的老毛病。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_116"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏的血液凝固了。一个锁住的门。一根断掉的电话线。一个三楼的高度。"
        - textKey: "她被困住了。"
  - nodeId: "N_TestStory_117"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "千夏。别担心。"
        - textKey: "我会照顾你的。就像我照顾由纪一样。"
  - nodeId: "N_TestStory_118"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "由纪。这个名字再次出现了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_119"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "由纪…就是你的前女友？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_120"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "嗯。她也在这里住过一段时间。"
        - textKey: "但后来她离开了。她说要去东京追求梦想。"
  - nodeId: "N_TestStory_121"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏注意到拓哉说离开的时候，手指不自觉地收紧了。"
        - textKey: "千夏在客房里度过了第一个白天。拓哉出门上班前给她准备了午餐——便当盒里整齐地摆着饭团、玉子烧和小番茄。"
        - textKey: "千夏没有碰那个便当。她蜷缩在床上，盯着天花板，脑海中不断回响着继父的话。"
  - nodeId: "N_TestStory_122"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山健二"
      textKey: "\"你以为外面的人就会对你好？别做梦了。你这种人，除了我谁还会收留你？\""
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_123"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏用力摇头。不，拓哉和继父不一样。拓哉没有打过她，没有骂过她。他只是…"
        - textKey: "只是把她锁在了一个房间里。"
        - textKey: "下午，千夏终于忍不住饥饿，打开了便当。食物很好吃——和继父带回来的便利店便当完全不同。"
        - textKey: "傍晚时分，拓哉回来了。他带了一束新鲜的百合花。"
  - nodeId: "N_TestStory_124"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "今天过得怎么样？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_125"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "…拓哉。我想回家。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_126"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "我知道。"
        - textKey: "但千夏，你看看这个。"
  - nodeId: "N_TestStory_127"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "报纸的头版：\"足利市少女失踪案悬而未决，警方怀疑与网络交友有关。\""
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_128"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "这和我有什么关系？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_129"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "三个月前，一个17岁的女孩在足利市失踪。她和你一样，是来见网友的。"
        - textKey: "警方到现在都没找到她。"
  - nodeId: "N_TestStory_130"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏的背脊发凉。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_131"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "所以我不能让你走。外面太危险了。"
        - textKey: "等风头过去，我会亲自送你回家。好吗？"
  - nodeId: "N_TestStory_132"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏看着拓哉的手。那只手干净、修长，和继父粗糙肮脏的手完全不同。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_133"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "…真的吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_134"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "真的。我保证。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_135"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏慢慢伸出手。拓哉握住她的手，轻轻捏了捏。"
        - textKey: "千夏告诉自己：拓哉是在保护她。这不是囚禁，是保护。"
        - textKey: "但她没有看到，拓哉转身时嘴角那一抹意味深长的微笑。"
        - textKey: "第三天。千夏开始适应被囚禁的生活。或者说，她强迫自己适应。"
        - textKey: "拓哉每天出门前都会给她准备好三餐，每一餐都精心搭配。晚上回来后，他们会一起看书、画画、聊天。"
        - textKey: "如果忽略那扇锁着的门，这一切看起来就像是一对普通情侣的日常生活。"
  - nodeId: "N_TestStory_136"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "（内心独白）我一定是疯了。我居然开始觉得…这里比家里好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_137"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏被自己的想法吓了一跳。但事实是，在这里没有人会骂她赔钱货，没有人会掰响小指关节威胁她。"
        - textKey: "拓哉对她说话总是温和的，从不大声。他会认真看她的画，会记得她喜欢吃什么，会在她睡不着的时候给她读太宰治的小说。"
        - textKey: "这种温柔的囚禁，比继父的暴力更加危险。因为千夏开始动摇了。"
  - nodeId: "N_TestStory_138"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "千夏，今天画了什么？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_139"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "画了你。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_140"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏画的是拓哉读书的侧脸。画中的拓哉看起来温文尔雅，金色瞳色在台灯光线下柔和地闪烁。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_141"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "…画得真好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_142"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "拓哉的反应出乎千夏的意料。他的眼眶竟然红了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_143"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "从来没有人…为我画过画。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_144"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏看着拓哉的表情，心中涌起一种复杂的情绪。她应该恨这个囚禁她的人。但此刻，她看到的只是一个渴望被理解的孤独灵魂。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_145"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "拓哉…你为什么把我留在这里？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_146"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "井上拓哉"
      lines:
        - textKey: "因为我不想失去你。"
        - textKey: "由纪离开的时候，我没有挽留。我以为她会回来。但她没有。"
        - textKey: "我不想再犯同样的错误。"
  - nodeId: "N_TestStory_147"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏感到一阵寒意。拓哉的话听起来像是爱情宣言，但背后隐藏着令人恐惧的占有欲。"
        - textKey: "她必须逃出去。不是今天，不是明天，但总有一天。在彻底迷失之前。"
        - textKey: "千夏开始在画作中隐藏信息。她在每幅画的角落里画上小小的符号——摩斯密码。"
        - textKey: "SOS。帮助。求救。"
        - textKey: "她把画挂在客厅的墙上，和拓哉的其他收藏品混在一起。拓哉从未注意到那些细小的符号。"
        - textKey: "这是千夏的秘密。也是她唯一能够维持理智的方式。"
        - textKey: "——序列一·蜘蛛之丝·完——"
        - textKey: "千夏被囚禁的第七天。她开始记录每一天发生的事情——用画笔代替文字。"
        - textKey: "在她的画中，拓哉是一个有着金色眼睛的影子。有时温柔，有时可怕。她画不出他的真实面貌，因为她自己也无法确定哪一个才是真正的拓哉。"
        - textKey: "这一天，拓哉带回家一本新的画册——《古斯塔夫·克里姆特全集》。"
  - nodeId: "N_TestStory_148"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "听说你喜欢象征主义。克里姆特是最伟大的象征主义画家之一。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_149"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "…你从哪里听说我喜欢象征主义？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_150"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "你在BBS上提过啊。不记得了吗？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_151"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏脊背发凉。她在BBS上确实提过，但那是在很久以前的帖子里。拓哉记得她说的每一句话。"
        - textKey: "这种被完全了解的感觉既令人安心又令人恐惧。"
  - nodeId: "N_TestStory_152"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "千夏。你的画里…为什么总有笼子？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_153"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "千夏心跳加速。她画的是一只鸟在笼子里——但她以为自己隐藏得很好。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_154"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "只是…随便画的。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_155"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "（微笑）是吗。我以为你在暗示什么。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_156"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "那一刻，千夏明白了——拓哉什么都知道。他知道她想逃跑。但他不担心，因为他确信她逃不掉。"
        - textKey: "这种被完全掌控的感觉，比任何暴力都更令人绝望。"
        - textKey: "千夏走出大船站，眼前的东京街道比她想象中更加拥挤。高楼大厦之间，穿着西装的上班族像鱼群一样在人行道上穿梭，没有人注意到一个提着旧皮箱的17岁少女。"
  - nodeId: "N_TestStory_157"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "（自言自语）镰仓…和杂志上看到的完全不一样。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_158"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "她按照拓哉在传呼机上留下的地址，换乘了两次电车，最终来到一栋位于住宅区的老旧公寓楼前。这栋楼外墙的白色涂料已经斑驳脱落，露出底下灰色的水泥，但阳台上的花草却修剪得整整齐齐。"
        - textKey: "千夏站在303号室门前，深吸了一口气。她的心跳得厉害，不是因为紧张，而是因为一种奇怪的期待——半年来，拓哉是她唯一的精神支柱。"
        - textKey: "门开了。"
  - nodeId: "N_TestStory_159"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "千夏？你比预计的早到了二十分钟。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_160"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "对不起，电车比想象中快…"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_161"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "笨蛋，不用道歉。进来吧，外面很热吧。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_162"
    nodeType: Dialogue
    dialogue:
      speakerId: "旁白"
      textKey: "房间比千夏想象的要整洁。一张单人床，一张书桌，一个简易的厨房角落。书桌上放着一台286电脑，屏幕保护程序正在循环播放着几何图案。墙边靠着几个画框，里面是千夏这半年来寄给他的素描复印件。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_163"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "这些…你都留着？"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_164"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "当然。每一张我都扫描进电脑了。你看，这张猫咪的线条进步很明显。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_165"
    nodeType: Dialogue
    dialogue:
      speakerId: "森山千夏"
      textKey: "那是我晚上躲在棉被里用手电筒画的…被爸爸——被健二发现的话，又要挨骂了。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_166"
    nodeType: Dialogue
    dialogue:
      speakerId: "井上拓哉"
      textKey: "以后不用躲了。这里就是你的画室。"
      speechRate: 1
      voiceAsset: ""
  - nodeId: "N_TestStory_167"
    nodeType: MultiDialogue
    multiDialogue:
      speakerId: "旁白"
      lines:
        - textKey: "千夏的眼眶微微泛红。不是因为悲伤，而是因为太久没有人对她这么好过了。"
        - textKey: "窗外，东京的蝉鸣声此起彼伏。这个夏天，将是她人生的转折点。"
        - textKey: "千夏的故事，才刚刚开始。每一个选择，都将决定她命运的走向。"
        - textKey: "千夏的旅途，由此启程。"
  - nodeId: "N_TestStory_168_End"
    nodeType: End

